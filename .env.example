# ─────────────────────────────────────────────
# Discord Bot
# ─────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
# 可选：仅在指定服务器同步斜杠指令（调试用，留空则全局同步）
DEV_GUILD_ID=

# ─────────────────────────────────────────────
# AI 推理后端（宿主机 LM Studio，OpenAI 兼容接口）
# ─────────────────────────────────────────────
AI_BASE_URL=http://192.168.0.58:1234/v1
AI_MODEL=gemma-4-26b-a4b-it
AI_API_KEY=not-needed-for-local

# ─────────────────────────────────────────────
# 第三方 API
# ─────────────────────────────────────────────
# AniList 公开 GraphQL 无需密钥；天气使用 Open-Meteo（免费免密钥）
ANILIST_API_URL=https://graphql.anilist.co
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
# 默认城市坐标（用于早安简报天气），例：悉尼
WEATHER_LAT=-33.8688
WEATHER_LON=151.2093

# ─────────────────────────────────────────────
# 运行环境
# ─────────────────────────────────────────────
TZ=Australia/Sydney
DATABASE_PATH=/app/bot_data/butler.db
